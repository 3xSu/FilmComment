# 电影MCP服务器环境配置示例
# 请复制此文件为 .env 并填入实际的API密钥

# TMDB API配置 (需要申请: https://www.themoviedb.org/settings/api)
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE

# 服务器配置
SERVER_PORT=3000
SERVER_HOST=localhost

# 日志级别
LOG_LEVEL=info

# 缓存配置
CACHE_TTL=3600
CACHE_ENABLED=true

# 请求限制
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# 超时配置
REQUEST_TIMEOUT=5000
RETRY_ATTEMPTS=3